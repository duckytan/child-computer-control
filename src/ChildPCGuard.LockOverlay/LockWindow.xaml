<Window x:Class="ChildPCGuard.LockOverlay.LockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChildPCGuard - 锁屏"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Border Background="#1E1E1E" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="ChildPCGuard"
                           FontSize="48"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock x:Name="LockMessage"
                           Text="今天的使用时间已到，休息一下吧！"
                           FontSize="24"
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <TextBlock x:Name="CountdownText"
                           Text=""
                           FontSize="72"
                           FontWeight="Bold"
                           Foreground="#FF6B6B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <TextBlock Text="请输入家长密码解锁"
                           FontSize="16"
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <PasswordBox x:Name="PasswordBox"
                             Width="300"
                             Height="50"
                             FontSize="20"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,20"
                             VerticalContentAlignment="Center"
                             Padding="10,0"/>

                <Button x:Name="UnlockButton"
                        Content="解锁"
                        Width="300"
                        Height="50"
                        FontSize="20"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"
                        Click="UnlockButton_Click"
                        Cursor="Hand"/>

                <TextBlock x:Name="ErrorText"
                           Text=""
                           FontSize="14"
                           Foreground="#FF6B6B"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>

                <TextBlock Text="紧急解锁：连续按 Ctrl+Alt+Shift+F12 五次"
                           FontSize="12"
                           Foreground="#666666"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
